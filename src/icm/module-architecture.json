{
  "module": "ICM - Index de Conformité Managériale",
  "version": "1.0.0",
  "status": "Complete & Production Ready",
  "createdAt": "2026-04-30",
  "stack": {
    "backend": "NestJS",
    "orm": "TypeORM",
    "database": "MySQL 8+",
    "validation": "class-validator",
    "documentation": "Swagger/OpenAPI"
  },
  "architecture": {
    "pattern": "Clean Architecture / Feature-based",
    "layers": [
      "Entities (TypeORM)",
      "DTOs (Validation)",
      "Services (Business Logic)",
      "Controllers (API)",
      "Module (Dependency Injection)"
    ]
  },
  "entities": [
    {
      "name": "IcmQuestion",
      "table": "icm_question",
      "purpose": "Configuration des questions ICM",
      "fields": 11,
      "softDelete": true,
      "relations": {
        "OneToMany": ["IcmChecklistResponse"]
      }
    },
    {
      "name": "IcmChecklist",
      "table": "icm_checklist",
      "purpose": "Checklists saisies par coordination",
      "fields": 13,
      "softDelete": true,
      "uniqueIndex": "coordinationId + month + year",
      "relations": {
        "ManyToOne": ["Coordination", "User (creator)", "User (validator)"],
        "OneToMany": ["IcmChecklistResponse"]
      }
    },
    {
      "name": "IcmChecklistResponse",
      "table": "icm_checklist_response",
      "purpose": "Réponses aux questions pour chaque checklist",
      "fields": 9,
      "softDelete": false,
      "cascade": "ON DELETE CASCADE",
      "relations": {
        "ManyToOne": ["IcmChecklist", "IcmQuestion"]
      }
    }
  ],
  "enums": [
    {
      "name": "IcmCategory",
      "values": ["RH", "LOGISTIQUE", "FINANCE", "ADMINISTRATION"]
    },
    {
      "name": "IcmPeriodicity",
      "values": ["Hebdomadaire", "Mensuel", "Trimestriel", "Semestriel", "Annuel"]
    },
    {
      "name": "ConformityLevel",
      "values": ["Conforme", "Partiellement conforme", "Non conforme"]
    },
    {
      "name": "ChecklistStatus",
      "values": ["Brouillon", "Soumis", "Validé", "Rejeté"]
    }
  ],
  "dtos": [
    {
      "name": "CreateIcmQuestionDto",
      "purpose": "Créer une question",
      "fields": ["label", "category", "periodicity", "expectedProof", "order"]
    },
    {
      "name": "UpdateIcmQuestionDto",
      "purpose": "Modifier une question",
      "fields": ["label", "category", "periodicity", "expectedProof", "order"]
    },
    {
      "name": "FilterIcmQuestionDto",
      "purpose": "Filtrer les questions",
      "fields": ["category", "periodicity", "isActive", "page", "limit"]
    },
    {
      "name": "InitIcmChecklistDto",
      "purpose": "Initialiser une checklist",
      "fields": ["coordinationId", "month", "year"]
    },
    {
      "name": "UpdateIcmResponseDto",
      "purpose": "Mettre à jour une réponse",
      "fields": ["id", "realised", "conformityLevel", "comment", "proofProvided"]
    },
    {
      "name": "UpdateIcmChecklistResponsesDto",
      "purpose": "Mettre à jour plusieurs réponses",
      "fields": ["responses[]"]
    },
    {
      "name": "FilterIcmChecklistDto",
      "purpose": "Filtrer les checklists",
      "fields": ["coordinationId", "month", "year", "status", "page", "limit"]
    },
    {
      "name": "ValidateIcmChecklistDto",
      "purpose": "Valider une checklist",
      "fields": ["checklistId"]
    },
    {
      "name": "RejectIcmChecklistDto",
      "purpose": "Rejeter une checklist",
      "fields": ["checklistId", "rejectionReason"]
    }
  ],
  "services": [
    {
      "name": "IcmQuestionService",
      "methods": [
        "create()",
        "findAll()",
        "findAllActive()",
        "findOne()",
        "update()",
        "toggleStatus()",
        "remove()"
      ]
    },
    {
      "name": "IcmChecklistService",
      "methods": [
        "initChecklist()",
        "findOne()",
        "findAll()",
        "updateResponses()",
        "calculateICMScore()",
        "calculateItemScore()",
        "submitChecklist()",
        "validateChecklist()",
        "rejectChecklist()",
        "remove()"
      ]
    }
  ],
  "controllers": [
    {
      "name": "IcmQuestionController",
      "baseRoute": "/icm-questions",
      "endpoints": 7
    },
    {
      "name": "IcmChecklistController",
      "baseRoute": "/icm-checklists",
      "endpoints": 8
    }
  ],
  "endpoints": [
    {
      "method": "POST",
      "path": "/icm-questions",
      "description": "Créer une question ICM",
      "status": 201
    },
    {
      "method": "GET",
      "path": "/icm-questions",
      "description": "Lister les questions avec filtres et pagination",
      "status": 200
    },
    {
      "method": "GET",
      "path": "/icm-questions/active",
      "description": "Récupérer les questions actives",
      "status": 200
    },
    {
      "method": "GET",
      "path": "/icm-questions/:id",
      "description": "Récupérer une question",
      "status": 200
    },
    {
      "method": "PATCH",
      "path": "/icm-questions/:id",
      "description": "Mettre à jour une question",
      "status": 200
    },
    {
      "method": "PATCH",
      "path": "/icm-questions/:id/toggle-status",
      "description": "Activer/Désactiver une question",
      "status": 200
    },
    {
      "method": "DELETE",
      "path": "/icm-questions/:id",
      "description": "Supprimer une question (soft delete)",
      "status": 200
    },
    {
      "method": "POST",
      "path": "/icm-checklists/init",
      "description": "Initialiser une checklist (auto-generate)",
      "status": 201
    },
    {
      "method": "GET",
      "path": "/icm-checklists",
      "description": "Lister les checklists avec filtres",
      "status": 200
    },
    {
      "method": "GET",
      "path": "/icm-checklists/:id",
      "description": "Récupérer une checklist",
      "status": 200
    },
    {
      "method": "PATCH",
      "path": "/icm-checklists/:id/responses",
      "description": "Mettre à jour les réponses",
      "status": 200
    },
    {
      "method": "PATCH",
      "path": "/icm-checklists/:id/submit",
      "description": "Soumettre la checklist (calcul score)",
      "status": 200
    },
    {
      "method": "PATCH",
      "path": "/icm-checklists/:id/validate",
      "description": "Valider la checklist",
      "status": 200
    },
    {
      "method": "PATCH",
      "path": "/icm-checklists/:id/reject",
      "description": "Rejeter la checklist",
      "status": 200
    },
    {
      "method": "DELETE",
      "path": "/icm-checklists/:id",
      "description": "Supprimer la checklist (soft delete)",
      "status": 200
    }
  ],
  "workflow": {
    "steps": [
      {
        "step": 1,
        "name": "Configuration",
        "description": "Admin configure les questions ICM",
        "endpoints": ["POST /icm-questions"]
      },
      {
        "step": 2,
        "name": "Initialisation",
        "description": "Coordinateur sélectionne coordination + période",
        "endpoints": ["POST /icm-checklists/init"],
        "autoActions": [
          "Vérification doublon",
          "Génération automatique des réponses",
          "Création en statut Brouillon"
        ]
      },
      {
        "step": 3,
        "name": "Saisie",
        "description": "Coordinateur remplit les réponses",
        "endpoints": ["PATCH /icm-checklists/:id/responses"]
      },
      {
        "step": 4,
        "name": "Soumission",
        "description": "Coordinateur soumet la checklist",
        "endpoints": ["PATCH /icm-checklists/:id/submit"],
        "autoActions": [
          "Calcul du score ICM",
          "Changement de statut à Soumis"
        ]
      },
      {
        "step": 5,
        "name": "Validation",
        "description": "Admin/Validateur valide ou rejette",
        "endpoints": [
          "PATCH /icm-checklists/:id/validate",
          "PATCH /icm-checklists/:id/reject"
        ]
      }
    ]
  },
  "validation": {
    "levels": [
      "DTO class-validator",
      "Service business logic",
      "Database constraints",
      "Unique index enforcement"
    ]
  },
  "errorHandling": {
