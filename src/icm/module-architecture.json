      "NotFoundException - Ressource non trouvée",
      "ConflictException - Conflit (doublon)",
      "InternalServerErrorException - Erreur serveur"
    ]
  },
  "security": {
    "features": [
      "Soft delete (pas de suppression définitive)",
      "Transactions atomiques",
      "Unique index sur (coordination, mois, année)",
      "Foreign key constraints",
      "DTO validation robuste",
      "Try/catch généralisés",
      "Exception handling spécifique"
    ]
